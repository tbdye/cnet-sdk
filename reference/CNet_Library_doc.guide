 @{"CNetAddressToAccount" LINK "CNetAddressToAccount"} - find account number for given CNet mail ID
 @{"CNetAddressType     " LINK "CNetAddressType"     } - examine given mail address and discern its type
 @{"CNetDisposeDir      " LINK "CNetDisposeDir"      } - free complete file list returned by CNetReadDir()
 @{"CNetIDToUUCP        " LINK "CNetIDToUUCP"        } - look-up UUCP/MailID from user serial IDNumber
 @{"CNetReadDir         " LINK "CNetReadDir"         } - read directory into linked list CNetFileEntries
 @{"CNetSearchEntry     " LINK "CNetSearchEntry"     } - search linked list of CNetFileEntries for file pattern
 @{"ConvertAccess       " LINK "ConvertAccess"       } - convert flag/bit range string to a packed LONG value
 @{"CopyFilterText      " LINK "CopyFilterText"      } - copy text, remove MCI/CR/LF, change TABs to spaces
 @{"CountDirEntries     " LINK "CountDirEntries"     } - count number of entries on list of CNetFileEntries
 @{"CreateDirEntry      " LINK "CreateDirEntry"      } - allocate & fill memory for a CNetFileEntry structure 
 @{"CreateFolderName    " LINK "CreateFolderName"    } - fill string with full path to user's mail folder
 @{"CreateMailDir       " LINK "CreateMailDir"       } - create path where user's mail is to be filed
 @{"DelayAddItems       " LINK "DelayAddItems"       } - delay the saving of items to subboard data files
 @{"DirectorySize       " LINK "DirectorySize"       } - Obtain the amount of space used (in bytes)
 @{"EntryOrdinal        " LINK "EntryOrdinal"        } - find ordinal number of a CNetFileEntry in list
 @{"ExpandFlags         " LINK "ExpandFlags"         } - convert a packed LONG flags value to a range string
 @{"FileExists          " LINK "FileExists"          } - check if a file exists
 @{"FileOLM             " LINK "FileOLM"             } - send OLM to CNet port.
 @{"FileSize            " LINK "FileSize"            } - check if file exists
 @{"FindHandle          " LINK "FindHandle"          } - find account to which a handle belongs
 @{"FindOrdinal         " LINK "FindOrdinal"         } - get the Nth node of an Exec list
 @{"FindParent          " LINK "FindParent"          } - find parent entry (list) for CNetFileEntry list
 @{"FindPhone           " LINK "FindPhone"           } - Find account user to which phone number belongs
 @{"FlushAddItems       " LINK "FlushAddItems"       } - save delayed items to subboard data files
 @{"FormatVanilla       " LINK "FormatVanilla"       } - Strip MCI and ANSI from file & break lines at 80 cols
 @{"FormDate            " LINK "FormDate"            } - Create an IsDate structure from an Amiga DateStamp
 @{"FreeText            " LINK "FreeText"            } - mark a block of subboard text free for future usage
 @{"GetDirEntry         " LINK "GetDirEntry"         } - get pointer to CNetFileEntry specified ordinal number
 @{"GetRFCDate          " LINK "GetRFCDate"          } - create an internet RFC date string
 @{"GetVolAssList       " LINK "GetVolAssList"       } - get list of available volumes and assigns
 @{"GiveAmigaDays       " LINK "GiveAmigaDays"       } - find number of days diff between a date and 01-01-1978
 @{"HeaderEntry         " LINK "HeaderEntry"         } - get header entry for CNetFileEntry list
 @{"HNameToUUCP         " LINK "HNameToUUCP"         } - look-up UUCP/MailID by handle/real name
 @{"IDToAccount         " LINK "IDToAccount"         } - find account number given unique user serial ID
 @{"InStr               " LINK "InStr"               } - examine a string to see if second string is sub-string
 @{"IsNowOnLine         " LINK "IsNowOnLine"         } - examine if user is online
 @{"LastEntry           " LINK "LastEntry"           } - get the bottom entry of CNetFileEntry list
 @{"LockAccount         " LINK "LockAccount"         } - lock an account to view/edit/copy attributes
 @{"LookupIdentd        " LINK "LookupIdentd"        } - remove identd entry for specified socket number
 @{"MakeDateZone        " LINK "MakeDateZone"        } - Create ASCII date according to given timezone
 @{"MCIFilter           " LINK "MCIFilter"           } - filter/disable MCI in the given string
 @{"MCIRemove           " LINK "MCIRemove"           } - remove all MCI from given string
 @{"NextDirEntry        " LINK "NextDirEntry"        } - find next entry in list of CNetFileEntries
 @{"NumFromUnique       " LINK "NumFromUnique"       } - find physical subboard number
 @{"OneLessUser         " LINK "OneLessUser"         } - decrement subboard current usage count/locks by one
 @{"OneMoreUser         " LINK "OneMoreUser"         } - increase subboard current usage/lock count by one
 @{"PItemToArgV         " LINK "PItemToArgV"         } - converts CNet parsed items to standard argv array
 @{"PrevDirEntry        " LINK "PrevDirEntry"        } - find previous entry in list of CNetFileEntries
 @{"RemoveIdentdUser    " LINK "RemoveIdentdUser"    } - remove identd entry for the specified socket number
 @{"ReplaceText         " LINK "ReplaceText"         } - replace a block of text in a string
 @{"SaveFree            " LINK "SaveFree"            } - save subboard text "hole" information
 @{"StartupInitCache    " LINK "StartupInitCache"    } - initalize the CNet user cache
 @{"StrToUpper          " LINK "StrToUpper"          } - convert a string to all uppercase
 @{"UCacheDispose       " LINK "UCacheDispose"       } - free resources used by the user cache
 @{"UCacheInitUser      " LINK "UCacheInitUser"      } - initialize cache entry for user
 @{"UCacheLookup        " LINK "UCacheLookup"        } - obtain cache entry for user
 @{"UCacheRead          " LINK "UCacheRead"          } - read sequential block of accounts from user cache
 @{"UCacheWrite         " LINK "UCacheWrite"         } - write sequential block of accounts to user cache
 @{"UltimateFindParts   " LINK "UltimateFindParts"   } - find the number of parts in a range
 @{"UnLockAccount       " LINK "UnLockAccount"       } - unlock a user account
 @{"WriteLog            " LINK "WriteLog"            } - add an entry to a standard CNet log
 @{"XAddCharge          " LINK "XAddCharge"          } - add a charge
 @{"ZAddItem            " LINK "ZAddItem"            } - Post new Item (post or file) to the message/file base
 @{"ZAddMessage         " LINK "ZAddMessage"         } - post new message (response) to the message/file base
 @{"ZGetItem            " LINK "ZGetItem"            } - Load Item (post or file) from the message/file base
 @{"ZPutItem            " LINK "ZPutItem"            } - Save Item (post or file) to the message/file base
@ENDNODE

@NODE "AccountToID" "AccountToID"
@TOC "MAIN"

Function         : AccountToID

Prototype        : LONG AccountToID( LONG account);

Purpose          : Converts a user account number to the user's unique serial ID
                   Using the serial ID to reference a user makes sense as
                   no two users will ever have the same serial ID as, unlike
                   account numbers, serial ID numbers are not reused.

Arguments        : account - the account number of the user whose serial ID
                             you would like to obtain.

Returns          : the serial ID of the given user account

Known bugs       : does no validity checking on the account number.  YOU
                   must make sure the account number is greater than zero and
                   less than myp->Nums[0] where myp->Nums[0] is the highest
                   account number in use.

See also         : @{"IDToAccount()" LINK "IDToAccount"}
@ENDNODE

@NODE "AddCredits" "AddCredits"
@TOC "MAIN"

Function         : AddCredits

Prototype        : void AddCredits(struct @{"ItemType3" LINK "cnetinclude:subs.h/main" 191} *i, short m);

Purpose          : Award user credits ..

Arguments        : i  - item for which the credits are being applied
                   m  - multiplier - byte/file rewards are multipled by this value.

Returns          : none

Known bugs       : none
@ENDNODE

@NODE "AddIdentdUser" "AddIdentdUser"
@TOC "MAIN"

Function         : AddIdentdUser

Prototype        : BYTE AddIdentdUser( short Port, LONG Socket);

Purpose          : Add an identd entry for the given port/socket combo

Arguments        : Port - CNetPort number
                   Socket - a socket number to associate with the given CNet
                            port.  Note that more than one socket association
                            may exist for a given port.

Returns          : 0 on success
                   1 if MainPort could not be found
                   2 if resource allocation failed

Known bugs       : none

See also         : 
@ENDNODE

